# FindMe RS — Environment Configuration
# Copy to .env and fill in real values. Never commit .env.

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=findme_rs_db
DB_USER=root
DB_PASSWORD=change_me

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Recommender cache ─────────────────────────────────────────────────────────
# Seconds before the in-memory data is reloaded from MySQL
RECS_CACHE_TTL_SECONDS=300

# Default number of recommendations returned per request
DEFAULT_TOP_N=12
